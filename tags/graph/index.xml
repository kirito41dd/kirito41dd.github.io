                <span class="k">if</span><span class="p">(</span><span class="o">!</span><span class="n">vst</span><span class="p">[</span><span class="n">edge</span><span class="p">[</span><span class="n">i</span><span class="p">].</span><span class="n">v</span><span class="p">]){</span>
